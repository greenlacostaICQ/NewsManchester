<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.mnewsdigest.bot-updates</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>__RUNTIME_ROOT__/scripts/process_bot_updates.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>WorkingDirectory</key>
    <string>__RUNTIME_ROOT__</string>

    <key>StandardOutPath</key>
    <string>__RUNTIME_ROOT__/data/state/bot-updates.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__RUNTIME_ROOT__/data/state/bot-updates.stderr.log</string>

    <key>RunAtLoad</key>
    <true/>
  </dict>
</plist>
