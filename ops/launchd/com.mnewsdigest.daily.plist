<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.mnewsdigest.daily</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>__RUNTIME_ROOT__/scripts/run_daily_digest.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>__RUNTIME_ROOT__</string>

    <key>StandardOutPath</key>
    <string>__RUNTIME_ROOT__/data/state/launchd.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__RUNTIME_ROOT__/data/state/launchd.stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
  </dict>
</plist>
