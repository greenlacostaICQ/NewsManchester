.env.local
__pycache__/
.pytest_cache/
*.pyc

# State files — ignored by default, but key cross-day files are tracked below
data/state/*.json
data/state/*.html
data/state/*.txt
data/state/daily_index/

# Track these: cross-day dedup, subscriber list, delivery history, last digest
!data/state/published_facts.json
!data/state/dedupe_memory.json
!data/state/bot_state.json
!data/state/delivery_state.json

data/archive/*.md
data/experiments/
